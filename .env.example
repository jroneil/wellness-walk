# Normal mode: leave disabled. For bundled Radicale development, change to true
# and use http://radicale:5232/, wellness, and wellness-dev-only below.
# Docker services use http://radicale:5232/; host tools use http://localhost:5232/.
# For a real provider, prefer HTTPS and an app password.
CALDAV_ENABLED=false
CALDAV_SERVER_URL=http://radicale:5232/
CALDAV_USERNAME=wellness
CALDAV_PASSWORD=wellness-dev-only
CALDAV_CALENDAR_PATH=
CALDAV_CALENDAR_IDS=
CALDAV_DEFAULT_TIMEZONE=America/New_York
CALDAV_LOOKAHEAD_DAYS=7
CALDAV_MAX_OCCURRENCES_PER_EVENT=500
CALDAV_MAX_EVENTS_PER_CALENDAR=2000
CALDAV_MAX_RESPONSE_BYTES=2000000
CALDAV_MAX_EXPANSION_DAYS=31
CALDAV_CONNECTION_TIMEOUT=3s
CALDAV_READ_TIMEOUT=5s
POSTGRES_DB=wellness
POSTGRES_USER=wellness
POSTGRES_PASSWORD=replace-with-a-development-password
# Required for CalDAV/Google credentials. This command produces exactly 32 bytes,
# then Base64-encodes them: openssl rand -base64 32
# CalDAV development value: PROVIDER_CREDENTIAL_MASTER_KEY=<generate-a-secure-value>
PROVIDER_CREDENTIAL_MASTER_KEY=
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:9090/api/calendar/providers/GOOGLE/oauth/callback
CALENDAR_OAUTH_FRONTEND_SUCCESS_URL=http://localhost:3000/calendar?oauth=success
CALENDAR_OAUTH_FRONTEND_FAILURE_URL=http://localhost:3000/calendar?oauth=failure
